//- Source: index.html
//- ⚠ Manual work: 1 item(s)
//-
//-   MANUAL: {maccms:gbook num="10" paging="yes" order="desc" by="id"} needs controller pre-query

html
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width = device-width ,initial-scale = 1,minimum-scale = 1,maximum-scale = 1,user-scalable =no,")
    title 留言板 - #{maccms.siteName}
    include ../block/include
    script
      | $(function(){
      | MAC.Gbook.Login = #{gbook.login};
      | MAC.Gbook.Verify = #{gbook.verify};
      | MAC.Gbook.Init();
      | });
  body
    include ../block/head
    div.container
      div.row
        div.col-lg-wide-3.col-xs-1
          div.stui-pannel.stui-pannel-bg.clearfix
            div.stui-pannel-box.clearfix
              div.stui-pannel_hd
                div.stui-pannel__head.clearfix
                  h3.title
                    | 我要留言
              div.col-pd.clearfix
                form.gbook_form
                  ul.gbook-form
                    li
                      textarea.form-control(name="gbook_content")
                    if gbook.verify === 1
                      li
                        input.mac_verify.form-control(type="text", name="verify", placeholder="验证码", style="width: 80px; display: inline-block; margin-right: 10px;")
                    li
                      input.btn.btn-primary.pull-right.gbook_submit(type="button", value="提交") input.btn.btn-default(type="reset", value="重新留言")
        div.col-lg-wide-7.col-xs-1
          //- MANUAL: maccms block (needs controller pre-query)
          p.text-red 管理员回复：#{item.gbook_reply}
          p.text-muted.font-12 #{item.gbook_time}
    include ../block/page
style(type="text/css")
  | .gbook-form li{ margin-bottom: 15px;}
  | .gbook-form li:last-child{ margin-bottom: 0;}
include ../block/foot