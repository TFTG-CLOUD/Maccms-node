extends ../layout
block content
  h2 编辑影视
  form#vod-edit-form(style="background:#fff;padding:20px;border-radius:4px;max-width:900px")
    .form-group
      label 名称
      input(type="text" name="name" required value=vod.name || '')
    .form-group
      label 副标题
      input(type="text" name="sub" value=vod.sub || '')
    .form-group
      label 英文标识
      input(type="text" name="en" value=vod.en || '')
    .form-group
      label 分类
      select(name="type")
        option(value="") 请选择分类
        each item in types
          option(value=item._id selected=String(vod.type || '') === String(item._id))= item.name
    .form-group
      label 年份
      input(type="text" name="year" value=vod.year || '')
    .form-group
      label 地区
      textarea(name="area" rows="2" placeholder="支持逗号、斜杠、顿号分隔")= vod.area || ''
    .form-group
      label 语言
      textarea(name="lang" rows="2" placeholder="支持逗号、斜杠、顿号分隔")= vod.lang || ''
    .form-group
      label 类型标签
      textarea(name="class" rows="2" placeholder="支持逗号、斜杠、顿号分隔")= vod.class || ''
    .form-group
      label 演员
      textarea(name="actor" rows="3" placeholder="支持逗号、斜杠、顿号分隔")= vod.actor || ''
    .form-group
      label 导演
      textarea(name="director" rows="3" placeholder="支持逗号、斜杠、顿号分隔")= vod.director || ''
    .form-group
      label 编剧
      textarea(name="writer" rows="3" placeholder="支持逗号、斜杠、顿号分隔")= vod.writer || ''
    .form-group
      label 封面
      input(type="text" name="pic" value=vod.pic || '')
    .form-group
      label 状态
      select(name="status")
        option(value="1" selected=Number(vod.status) === 1) 启用
        option(value="0" selected=Number(vod.status) !== 1) 禁用
    .form-group
      label 备注
      input(type="text" name="remarks" value=vod.remarks || '')
    .form-group
      label 简介
      textarea(name="content" rows="6")= vod.content || ''
    button.btn.btn-primary(type="submit") 保存
    a.btn(href="/admin/vod" style="margin-left:8px;background:#f5f5f5;color:#333") 返回

  script.
    document.getElementById('vod-edit-form').addEventListener('submit', async function (event) {
      event.preventDefault();
      const formData = new FormData(event.target);
      const payload = Object.fromEntries(formData.entries());
      const response = await fetch('/admin/vod/#{vod._id}', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      if (response.ok) {
        location.href = '/admin/vod';
        return;
      }
      alert('保存失败，请稍后重试');
    });
