div.stui-vodlist__box
  a.stui-vodlist__thumb.lazyload(href="`/vod/detail/id/${item._id}.html`", title="#{item.name}", data-original="#{item.pic}")
    span.play.hidden-xs
    span.pic-text.text-right  // MANUAL: Inline conditional - needs structural Pug conversion
  div.stui-vodlist__detail
    h4.title.text-overflow a(href="`/vod/detail/id/${item._id}.html`", title="#{item.name}") #{item.name}
    p.text.text-overflow.text-muted.hidden-xs #{item.actor || '内详'}