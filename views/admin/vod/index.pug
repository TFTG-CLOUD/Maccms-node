extends ../layout
block content
  h2 影视管理

  form(method="GET" action="/admin/vod" style="background:#fff;padding:20px;border-radius:4px;margin-bottom:20px")
    .form-group
      label 关键词
      input(type="text" name="wd" value=filter.wd || '' placeholder="影片名")
    .form-group
      label 分类
      select(name="type")
        option(value="") 全部分类
        each item in types
          option(value=item._id selected=String(filter.type || '') === String(item._id))= item.name
    .form-group
      label 状态
      select(name="status")
        option(value="") 全部状态
        option(value="1" selected=String(filter.status || '') === '1') 已启用
        option(value="0" selected=String(filter.status || '') === '0') 已禁用
    button.btn.btn-primary(type="submit") 筛选

  table
    tr
      th ID
      th 名称
      th 分类
      th 年份
      th 地区
      th 状态
      th 更新时间
      th 操作
    each item in list
      tr
        td= item._id
        td
          div(style="font-weight:600")= item.name
          if item.remarks
            div(style="color:#666;font-size:12px")= item.remarks
        td= item.typeName || (item.type || '-')
        td= item.year || '-'
        td= item.area || '-'
        td= item.status === 1 ? '启用' : '禁用'
        td= item.updatedAt ? new Date(item.updatedAt).toLocaleString() : '-'
        td
          a.btn.btn-primary(href='/admin/vod/' + item._id + '/edit' style='margin-right:8px') 编辑
          button.btn(type="button" onclick="auditVod('" + item._id + "', " + (item.status === 1 ? 0 : 1) + ")")= item.status === 1 ? '禁用' : '启用'
          button.btn.btn-danger(type="button" onclick="delVod('" + item._id + "')" style='margin-left:8px') 删除

  if total > pagesize
    - const totalPages = Math.ceil(total / pagesize)
    - const currentPage = Number(page || 1)
    .pagination(style="display:flex;gap:8px;align-items:center;margin-top:20px")
      span 共 #{total} 条
      if currentPage > 1
        a.btn(href=`/admin/vod?page=${currentPage - 1}&wd=${encodeURIComponent(filter.wd || '')}&type=${encodeURIComponent(filter.type || '')}&status=${encodeURIComponent(filter.status || '')}` style='background:#f5f5f5;color:#333') 上一页
      span 第 #{currentPage} / #{totalPages} 页
      if currentPage < totalPages
        a.btn(href=`/admin/vod?page=${currentPage + 1}&wd=${encodeURIComponent(filter.wd || '')}&type=${encodeURIComponent(filter.type || '')}&status=${encodeURIComponent(filter.status || '')}` style='background:#f5f5f5;color:#333') 下一页

  script.
    async function delVod(id) {
      if (!confirm('确定删除该影片吗？')) return;
      const response = await fetch('/admin/vod/' + id, { method: 'DELETE' });
      const data = await response.json();
      if (data.code === 1) {
        location.reload();
        return;
      }
      alert(data.msg || '删除失败');
    }

    async function auditVod(id, status) {
      const response = await fetch('/admin/vod/' + id + '/audit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: status })
      });
      const data = await response.json();
      if (data.code === 1) {
        location.reload();
        return;
      }
      alert(data.msg || '操作失败');
    }
