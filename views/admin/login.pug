doctype html
html(lang="zh-CN")
  head
    meta(charset="UTF-8")
    title 管理员登录
    style.
      body { display: flex; align-items: center; justify-content: center; height: 100vh; background: #f0f2f5; font-family: 'Microsoft YaHei', sans-serif; }
      .login-box { background: #fff; padding: 40px; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); width: 360px; }
      h2 { text-align: center; margin-bottom: 30px; }
      input { width: 100%; padding: 10px; margin-bottom: 15px; border: 1px solid #d9d9d9; border-radius: 4px; font-size: 14px; }
      button { width: 100%; padding: 10px; background: #1890ff; color: #fff; border: none; border-radius: 4px; font-size: 16px; cursor: pointer; }
      .error { color: #ff4d4f; margin-bottom: 15px; text-align: center; }
  body
    .login-box
      h2 MacCMS 后台登录
      if error && error.length
        .error= error[0] || error
      form(method="POST" action="/admin/login")
        input(type="text" name="name" placeholder="用户名" required)
        input(type="password" name="password" placeholder="密码" required)
        button(type="submit") 登录
