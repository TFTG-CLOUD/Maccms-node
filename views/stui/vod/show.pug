extends ../layout
include ../mixins

block content
  style.
    @media (max-width: 767px) {
      .stui-screen__list.type-slide.bottom-line-dot {
        padding-top: 4px;
      }
      .stui-screen__list.type-slide.bottom-line-dot li:first-child {
        padding-left: 0;
      }
    }
  .stui-pannel.stui-pannel-bg.clearfix
    .stui-pannel-box
      if subTypes && subTypes.length
        ul.stui-screen__list.type-slide.bottom-line-dot.clearfix
          li: span.text-muted 按类型
          li(class=(!param.id || (groupTypeId && param.id.toString() == groupTypeId.toString()) ? 'active' : '')): a(href=buildRootShowUrl()) 全部
          each t in subTypes
            li(class=(param.id && t._id.toString() == param.id.toString() ? 'active' : ''))
              a(href=buildTypeShowUrl(t._id))= t.name

      if filterOptions && filterOptions.areas && filterOptions.areas.length
        ul.stui-screen__list.type-slide.bottom-line-dot.clearfix
          li: span.text-muted 按地区
          li(class=(!param.area ? 'active' : '')): a(href=buildShowUrl({ area: null, page: null })) 全部
          each area in filterOptions.areas
            li(class=(param.area == area ? 'active' : '')): a(href=buildShowUrl({ area, page: null }))= area

      if filterOptions && filterOptions.years && filterOptions.years.length
        ul.stui-screen__list.type-slide.bottom-line-dot.clearfix
          li: span.text-muted 按年份
          li(class=(!param.year ? 'active' : '')): a(href=buildShowUrl({ year: null, page: null })) 全部
          each year in filterOptions.years
            li(class=(param.year == year ? 'active' : '')): a(href=buildShowUrl({ year, page: null }))= year

      ul.stui-screen__list.letter-list.type-slide.clearfix
        li: span.text-muted 按字母
        li(class=(!param.letter ? 'active' : '')): a(href=buildShowUrl({ letter: null, page: null })) 全部
        each letter in letterOptions || []
          li(class=(param.letter == letter ? 'active' : '')): a(href=buildShowUrl({ letter, page: null }))= letter

      .stui-pannel_hd
        .stui-pannel__head.active.bottom-line.clearfix
          ul.nav.nav-head
            li(class=(!param.by || param.by == 'time' ? 'active' : '')): a(href=buildShowUrl({ by: 'time', page: null })) 按时间
            li(class=(param.by == 'hits' ? 'active' : '')): a(href=buildShowUrl({ by: 'hits', page: null })) 按人气
            li(class=(param.by == 'score' ? 'active' : '')): a(href=buildShowUrl({ by: 'score', page: null })) 按评分

      .stui-pannel_bd
        ul.stui-vodlist.clearfix
          each vod in list
            li.col-md-6.col-sm-4.col-xs-3
              +vodBox(vod)

  +page(pageNav)
