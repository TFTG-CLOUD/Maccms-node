extends ../layout
include ../mixins

block content
  if type
    .stui-pannel.stui-pannel-bg.clearfix
      .stui-pannel-box
        .stui-pannel_hd
          .stui-pannel__head.clearfix
            h3.title= type.name

  .stui-pannel.stui-pannel-bg.clearfix
    .stui-pannel-box
      .stui-pannel_bd
        ul.stui-vodlist.clearfix
          each vod in list
            li.col-md-6.col-sm-4.col-xs-3
              +vodBox(vod)

  +page(pageNav)
